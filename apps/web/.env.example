NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Read-only public PAT used for USERNAME MODE (no-auth generation). When a
# visitor types a GitHub username without signing in, the server fetches their
# PUBLIC data with this token. Create a fine-grained PAT with no extra scopes
# (public read is the default) at https://github.com/settings/tokens and paste
# it here. Without it, username mode returns app_token_missing.
GITHUB_APP_TOKEN=
